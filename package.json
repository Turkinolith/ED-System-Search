{
  "name": "ed-system-search",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "native:build": "cargo build --release --manifest-path native/ed-data-importer/Cargo.toml",
    "import:systems": "node scripts/run-native-importer.js full --source systems.json.gz",
    "import:systems:native": "node scripts/run-native-importer.js full",
    "import:systems-delta": "node scripts/run-native-importer.js delta",
    "import:systems-delta:1day": "node scripts/run-native-importer.js delta --source https://downloads.spansh.co.uk/systems_1day.json.gz",
    "import:systems-delta:1week": "node scripts/run-native-importer.js delta --source https://downloads.spansh.co.uk/systems_1week.json.gz",
    "import:systems-delta:2weeks": "node scripts/run-native-importer.js delta --source https://downloads.spansh.co.uk/systems_2weeks.json.gz",
    "import:systems-delta:1month": "node scripts/run-native-importer.js delta --source https://downloads.spansh.co.uk/systems_1month.json.gz",
    "import:systems-delta:6months": "node scripts/run-native-importer.js delta --source https://downloads.spansh.co.uk/systems_6months.json.gz",
    "import:systems-delta:finish": "npm run import:spatial-index && npm run import:journals",
    "import:galaxy": "node scripts/run-native-importer.js galaxy --source galaxy.json.gz",
    "import:galaxy:download": "node scripts/run-native-importer.js galaxy --source https://downloads.spansh.co.uk/galaxy.json.gz",
    "import:galaxy-delta:1day": "node scripts/run-native-importer.js galaxy-delta --source https://downloads.spansh.co.uk/galaxy_1day.json.gz",
    "import:galaxy-delta:7days": "node scripts/run-native-importer.js galaxy-delta --source https://downloads.spansh.co.uk/galaxy_7days.json.gz",
    "import:galaxy-delta:1month": "node scripts/run-native-importer.js galaxy-delta --source https://downloads.spansh.co.uk/galaxy_1month.json.gz",
    "import:murder-binaries": "node scripts/run-native-importer.js murder-binaries",
    "import:murder-binaries:index": "node scripts/run-native-importer.js murder-index",
    "import:spatial-index": "node scripts/run-native-importer.js spatial-index",
    "inspect:galaxy": "node scripts/inspect-galaxy.js galaxy.json.gz",
    "test:galaxy": "node scripts/test-galaxy-integration.js",
    "test:journals": "node scripts/test-journal-bodies.js",
    "test:config": "node scripts/test-local-config.js",
    "test:stars": "node scripts/test-star-visuals.js",
    "import:journals": "node scripts/import-journals.js",
    "import:updates": "node scripts/import-updates.js systems.json.gz",
    "import:name-lookup": "node --max-old-space-size=98304 scripts/import-name-lookup.js",
    "import:suggestions": "node scripts/import-suggestions.js",
    "import:places": "node scripts/import-places.js",
    "import:discoveries": "node scripts/import-discoveries.js",
    "refresh:journals": "node scripts/import-journals.js"
  }
}
